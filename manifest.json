{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extName__",
  "version": "1.0.0",
  "description": "__MSG_extDesc__",
  "minimum_chrome_version": "111",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "shared/core.js",
        "shared/cues.js",
        "shared/translation.js",
        "shared/display.js",
        "shared/stream.js",
        "shared.js",
        "inject.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": false
    },
    {
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "shared/core.js",
        "shared/cues.js",
        "shared/translation.js",
        "shared/display.js",
        "shared/stream.js",
        "shared.js",
        "content/state-ui.js",
        "content/session.js",
        "content/cue-playback.js",
        "content/display.js",
        "content/semantic.js",
        "content/fallback.js",
        "content/export.js",
        "content/bridge.js",
        "content/lifecycle.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
